---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/react/Navbar';
import Hero from '../components/react/Hero';
import About from '../components/react/About';
import Experience from '../components/react/Experience';
import Projects from '../components/react/Projects';
import Education from '../components/react/Education';
import Contact from '../components/react/Contact';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<BaseLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Navbar client:load />
  <main class="flex flex-col gap-10 md:gap-20 pb-20">
    <Hero client:load />
    <About client:visible />
    <Experience client:visible />
    <Projects client:visible />
    <Education client:visible />
    <Contact client:visible />
  </main>
</BaseLayout>