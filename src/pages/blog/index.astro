---
import BaseLayout from "../../layouts/BaseLayout.astro";

const response = await fetch('https://dev.to/api/articles?username=adityaokke&per_page=10');
const posts = await response.json();
---

<BaseLayout title="Blog" description="My articles on Dev.to">
  <main class="max-w-4xl mx-auto px-6 py-20">
    <h1 class="text-3xl font-bold text-slate-200 mb-12">Blog</h1>
    <div class="flex flex-col gap-6">
      {posts.map((post: any) => (
		<a
          href={post.url}
          target="_blank"
          rel="noopener noreferrer"
          class="p-6 bg-slate-900 border border-slate-800 rounded-xl hover:border-emerald-500/30 transition-colors"
        >
          <h2 class="text-slate-200 font-semibold text-lg mb-2">{post.title}</h2>
          <p class="text-slate-400 text-sm mb-4">{post.description}</p>
          <div class="flex items-center gap-4 text-xs text-slate-500">
            <span>{new Date(post.published_at).toLocaleDateString()}</span>
            <span>{post.reading_time_minutes} min read</span>
            <span>❤️ {post.positive_reactions_count}</span>
          </div>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>